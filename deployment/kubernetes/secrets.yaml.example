# Copy to secrets.yaml and fill in base64-encoded values.
# To encode: echo -n 'value' | base64
# NEVER commit secrets.yaml to source control.
apiVersion: v1
kind: Secret
metadata:
  name: demo-secrets
  namespace: elastic-apm-demo
type: Opaque
data:
  ELASTIC_APM_SERVER_URL: <base64-encoded-url>
  ELASTIC_API_KEY: <base64-encoded-api-key>
  NEXT_PUBLIC_ELASTIC_APM_SERVER_URL: <base64-encoded-url>
