# =============================================================================
# Elastic Cloud Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to source control
# =============================================================================

# Elastic APM Server URL (from your Elastic Cloud deployment)
ELASTIC_APM_SERVER_URL=https://your-apm.apm.us-east-1.aws.elastic-cloud.com

# Elastic API Key (base64-encoded, for OTel Collector → Elastic Cloud auth)
ELASTIC_API_KEY=your_base64_api_key_here

# =============================================================================
# Frontend (Next.js) - these are baked into the browser bundle at build time
# =============================================================================
NEXT_PUBLIC_ELASTIC_APM_SERVER_URL=https://your-apm.apm.us-east-1.aws.elastic-cloud.com
NEXT_PUBLIC_ELASTIC_APM_SERVICE_NAME=demo-frontend
NEXT_PUBLIC_ELASTIC_APM_ENVIRONMENT=local

# =============================================================================
# Demo Scenario Flags (change and restart the affected service to activate)
# =============================================================================

# Scenario 2: Payment Failure — % of payments that fail (0-100)
PAYMENT_FAILURE_RATE=0

# Scenario 3: Slow Inventory — added latency in milliseconds (0 = normal)
INVENTORY_SLOW_MS=0
